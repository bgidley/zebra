# Copy to registry.env (git-ignored). OCIR push/pull credentials.
# OCI_USERNAME format: <tenancy-namespace>/<username>
#   - federated user: <namespace>/oracleidentitycloudservice/you@example.com
# OCIR_TOKEN: an OCI Auth Token (Console → Identity → Users → you → Auth Tokens → Generate).
OCI_USERNAME=mynamespace/oracleidentitycloudservice/you@example.com
OCIR_TOKEN=replace-with-oci-auth-token
OCI_EMAIL=you@example.com
