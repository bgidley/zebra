# Copy to smoke.env (git-ignored). Becomes the zebra-smoke-secrets k8s Secret.
# A DEDICATED Oracle schema, isolated from prod (mirrors the E2E_ORACLE_* pattern).
ORACLE_DSN=adb.uk-london-1.oraclecloud.com:1522/...smoke schema...
ORACLE_USERNAME=ZEBRA_SMOKE
ORACLE_PASSWORD=replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me
DJANGO_SECRET_KEY=replace-with-50-char-random
# Used by 50-smoke.sh to create the basic-auth smoke user and run the suite.
SMOKE_PASSWORD=replace-me
