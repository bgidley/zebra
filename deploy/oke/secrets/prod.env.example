# Copy to prod.env (git-ignored). Becomes the zebra-prod-secrets k8s Secret.
# These mirror the values currently in /home/gitlab-runner/.env on the VM.
ORACLE_DSN=adb.uk-london-1.oraclecloud.com:1522/...prod schema...
ORACLE_USERNAME=ZEBRA_PROD
ORACLE_PASSWORD=replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me
DJANGO_SECRET_KEY=replace-with-50-char-random
ZEBRA_DAILY_BUDGET_USD=50.00
ZEBRA_LLM_MODEL=opus
# Passkey / WebAuthn — must match the HTTPS origin served by the Tailscale subnet router.
WEBAUTHN_RP_ID=zebra-oke.tailf1e473.ts.net
WEBAUTHN_ORIGIN=https://zebra-oke.tailf1e473.ts.net
SESSION_COOKIE_SECURE=1
CSRF_TRUSTED_ORIGINS=https://zebra-oke.tailf1e473.ts.net
