# Copy to claude.env (git-ignored). Becomes the claude-secrets k8s Secret,
# mounted into the claude-code pod for the autonomous agent + dev work.
ANTHROPIC_API_KEY=sk-ant-replace-me
# Tokens so the pod can push branches / open PRs / drive CI:
GITLAB_TOKEN=glpat-replace-me
GH_TOKEN=ghp_replace-me
GIT_AUTHOR_NAME=Zebra Agent
GIT_AUTHOR_EMAIL=agent@example.com
