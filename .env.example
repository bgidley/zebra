# Zebra API Keys
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Anthropic API key for Claude models
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key for GPT models
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Oracle Cloud Database (for OracleStore)
# See: https://www.oracle.com/database/technologies/appdev/python/quickstartpython.html
ORACLE_USERNAME=USER_NAME
ORACLE_PASSWORD=PASSWORD

# Option 1: Direct DSN connection (requires mTLS disabled in Oracle Cloud Console)
# Note: Quote the DSN to handle special characters
ORACLE_DSN='(description=(retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1522)(host=adb.uk-london-1.oraclecloud.com))(connect_data=(service_name=xxx_zebra_high.adb.oraclecloud.com))(security=(ssl_server_dn_match=yes)))'

# Option 2: Wallet-based connection (for Oracle Cloud ADB with mTLS enabled - default)
# Download wallet from Oracle Cloud Console > Autonomous Database > Database Connection > Download Wallet
# ORACLE_DSN=zebra_high
# ORACLE_WALLET_LOCATION=/path/to/wallet
# ORACLE_WALLET_PASSWORD=wallet_password  # Only if wallet is encrypted
